# Announcement messages — every line of text the game speaks via NVDA / shows in the status bar / writes to the activity log.
# 
# Format: event_id: template
#   • Lines starting with '#' are comments. Blank lines are skipped.
#   • Templates use {placeholder} for runtime values (cat names, room
#     names, counts, etc.). Each event's available placeholders are
#     listed in the comment above its entry below — keep those names
#     if you customise the wording.
#   • Unknown placeholders fall back to the shipped default for that
#     event, so a typo can't crash the game mid-announcement.
#   • Save the file and restart Time for Family to pick up changes.

# placeholders: (no placeholders)
welcome_home: Welcome home.

# placeholders: (no placeholders)
new_game_started: Started a new game. Welcome home.

# placeholders: (no placeholders)
time_paused: Time paused.

# placeholders: (no placeholders)
time_resumed: Time resumed.

# placeholders: (no placeholders)
sounds_muted: Sounds muted.

# placeholders: (no placeholders)
sounds_unmuted: Sounds unmuted.

# placeholders: (no placeholders)
auto_breeding_off: Auto-breeding off.

# placeholders: (no placeholders)
auto_breeding_on: Auto-breeding on. Eligible pairs will breed on their own; you'll still get the basket dialog when one's ready.

# placeholders: {cat_a_name}, {cat_b_name}, {room_name}
pair_formed_one: {cat_a_name} and {cat_b_name} have become a pair in {room_name}.

# placeholders: {pair_descriptions}
pair_formed_many: New pairs formed: {pair_descriptions}.

# placeholders: {basket_label}, {pair_id}, {n}, {baby_word}
basket_ready_one: The {basket_label} from pair {pair_id} is ready — {n} {baby_word} waiting on your decision.

# placeholders: {n}
basket_ready_many: {n} baskets are now ready for decisions.

# placeholders: {parts}
baskets_summary: Baskets: {parts}.

# placeholders: {basket_label}, {room_name}, {pair_id}, {n}, {baby_word}, {duration}
auto_breed_basket_arrived: Auto-breeding: a {basket_label} arrived in {room_name} from pair {pair_id} — {n} {baby_word}, ready in {duration}.

# placeholders: {species_word}, {name}
auto_breed_village_birth: A new {species_word} was born in the village: {name}.

# placeholders: {meter}, {room_name}
meter_low_one: {meter} is getting low in {room_name}.

# placeholders: {summary}
meter_low_many: Meters getting low — {summary}.

# placeholders: {meter}, {room_name}
meter_low_returning_one: While you were away, {meter} ran low in {room_name}.

# placeholders: {summary}
meter_low_returning_many: While you were away, meters ran low — {summary}.

# placeholders: {verb}, {meter}
meter_refilled: {verb} {meter}.

# placeholders: {response}, {affection_pct}
pet_with_response: {response} Affection now {affection_pct}%.

# placeholders: {care}, {name}, {affection_pct}
pet_no_response: {care} {name}. Affection now {affection_pct}%.

# placeholders: (no placeholders)
select_creature: Select a creature first.

# placeholders: {species_label}
select_species: Select a {species_label} first.

# placeholders: {name}, {room_name}
creature_moved: {name} moved to {room_name}.

# placeholders: (no placeholders)
dig_no_left: No digs left today. Come back tomorrow.

# placeholders: (no placeholders)
dig_nothing: You dug, but found nothing this time.

# placeholders: {article}, {name}
dig_item: You dug up {article} {name}.

# placeholders: {name}, {description}
dig_object: You found an object: {name} — {description}

# placeholders: {name}, {description}
dig_treasure: You found a treasure: {name} — {description}

# placeholders: (no placeholders)
build_no_type: No room type selected.

